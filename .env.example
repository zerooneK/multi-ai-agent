# =============================================================================
#  Multi-Agent Team Framework — Environment Configuration
#
#  IMPORTANT: Never commit this file to Git.
# =============================================================================


# -----------------------------------------------------------------------------
# GLOBAL FALLBACK
# ใช้เมื่อ agent ไหนไม่ได้ตั้งค่า provider/model เอาไว้
# -----------------------------------------------------------------------------
AGENT_PROVIDER=anthropic
# AGENT_MODEL=claude-sonnet-4-20250514


# -----------------------------------------------------------------------------
# API KEYS — ใส่ key ของ provider ที่ใช้งาน
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=your-anthropic-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
OPENROUTER_API_KEY=your-openrouter-api-key-here
GEMINI_API_KEY=your-gemini-api-key-here
# Ollama ไม่ต้องใส่ key


# -----------------------------------------------------------------------------
# PER-AGENT MODEL SETTINGS
#
# แต่ละ agent สามารถใช้ provider และ model ที่ต่างกันได้อิสระ
# ถ้าไม่ตั้งค่า จะใช้ค่าจาก AGENT_PROVIDER / AGENT_MODEL ด้านบนแทน
#
# รูปแบบ:
#   <AGENT>_PROVIDER = ชื่อ provider
#   <AGENT>_MODEL    = ชื่อ model
# -----------------------------------------------------------------------------

# PLANNER — วิเคราะห์ requirement + วางแผน project
PLANNER_PROVIDER=anthropic
PLANNER_MODEL=claude-sonnet-4-20250514

# BACKEND — เขียน FastAPI + SQLAlchemy + Auth code
BACKEND_PROVIDER=anthropic
BACKEND_MODEL=claude-sonnet-4-20250514

# FRONTEND — เขียน Next.js 14 + TypeScript frontend
FRONTEND_PROVIDER=openai
FRONTEND_MODEL=gpt-4o-mini

# QA — ตรวจ syntax + review code + เขียน fix report
QA_PROVIDER=anthropic
QA_MODEL=claude-haiku-4-5-20251001


# -----------------------------------------------------------------------------
# OLLAMA SERVER (ถ้าใช้ Ollama)
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434/v1


# -----------------------------------------------------------------------------
# OUTPUT DIRECTORY
# -----------------------------------------------------------------------------
OUTPUT_DIR=output


# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
AGENT_LOG_LEVEL=INFO